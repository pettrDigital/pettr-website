rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // SMS conversations stored by phone number
    // Allow access via Firebase REST API with valid API key
    match /conversations/{phone} {
      allow read, write: if true;
    }

    // Booking flow state - SMS guided booking
    match /booking_flows/{phone} {
      allow read, write: if true;
    }
  }
}